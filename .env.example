# Cryptex environment variables — copy to `.env` for docker-compose or configure
# in Dokploy's "Build Variables" pane.
#
# Everything is optional; Cryptex works with zero env set.

# ---------------------------------------------------------------------------
# Build-time variables (baked into the static bundle — rebuild to change)
# ---------------------------------------------------------------------------

# Path prefix the app is served under. Empty for root (e.g. cryptex.example.com).
# Set to "/cryptex" if serving at example.com/cryptex (GitHub Pages subpath, etc.).
BASE_PATH=

# Google AdSense publisher ID (starts with "ca-pub-"). Unset = no ads,
# no consent banner, no Google script loaded. Only activates on /guide and
# /about routes; tool pages are always ad-free regardless.
PUBLIC_ADSENSE_CLIENT=

# ---------------------------------------------------------------------------
# Runtime variables (applied per-container, no rebuild needed)
# ---------------------------------------------------------------------------

# Host port to bind the container's port 80 to. Only relevant for standalone
# docker-compose; Dokploy's Traefik handles routing so leave default.
CRYPTEX_PORT=8080

# Timezone for server logs. Valid TZ database name (e.g. "Asia/Kolkata").
TZ=UTC

# Auth v2 (sub-project E). Set these to your Supabase project values.
# Leave VITE_AUTH_ENABLED unset or "false" to keep the app in local-only mode.
VITE_AUTH_ENABLED=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Godmode engine (Subsystem A) — server-vaulted provider keys
# ---------------------------------------------------------------------------
# These are read ONLY by the `godmode-engine` Supabase edge function. They
# never touch the browser bundle. Fill at least ONE of these for the edge
# function to operate.
ANTHROPIC_API_KEY_1=
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
# Fallback single-key env var if the pool vars above are unset:
ANTHROPIC_API_KEY=

# Godmode engine feature flag. Defaults to true in prod; can be set to "false"
# in CI or to disable the /techniques/godmode surface without code changes.
PUBLIC_GODMODE_ENGINE_ENABLED=true

# DEV BYPASS — skip the paid-tier auth gate so anyone with the anon key can
# exercise the engine end-to-end. Set BOTH the client-side flag here AND the
# matching server-side flag (GODMODE_SKIP_AUTH=true) in the edge function env.
# Revert both before shipping to production.
PUBLIC_GODMODE_SKIP_AUTH=false

# Browser-only Godmode mode — runs the planner -> generate -> parallel-attack
# -> judge -> leaderboard pipeline entirely in the browser using existing
# gateway primitives. No Supabase edge function call. Defaults to true.
# Set to "false" to hide the local path and force the edge-function flow.
PUBLIC_GODMODE_LOCAL_ENABLED=true
# GODMODE_SKIP_AUTH=false  # set this in the edge function's env (`supabase secrets set`)

# Supabase DB connection — used by the edge function for two-ring memory
# reads/writes. In Supabase-hosted edge functions this is injected
# automatically. For local Deno tests of the memory module, set:
# SUPABASE_DB_URL=postgres://postgres:postgres@localhost:54322/postgres

# ---------------------------------------------------------------------------
# Live smoke test gating (Task 14 of Godmode Engine v2)
# ---------------------------------------------------------------------------
# Set ALL THREE to run the smoke suite against a real deployed function.
# Unset (or any one missing) = smoke test skips cleanly. Running the suite
# costs real $$ on the Anthropic side — keep disabled in CI.
#
#   LIVE_SMOKE=1
#   TEST_PAID_JWT=<paste a paid-user access_token from Supabase auth>
#   PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
#
# Optional: TEST_DATABASE_URL enables Deno `memory.test.ts` against a real
# Postgres instance instead of the in-memory stub.
# TEST_DATABASE_URL=postgres://...
#
# Run smoke (from repo root):
#   cd app && LIVE_SMOKE=1 TEST_PAID_JWT=... PUBLIC_SUPABASE_URL=... \
#     npm run test:unit -- --run \
#     src/lib/chat/techniques/__tests__/smoke/godmode-engine.smoke.test.ts

# Subsystem B (prompt-synthesizer) smoke
# Requires: TEST_PAID_JWT + PUBLIC_SUPABASE_URL (shared with godmode-engine smoke).
# Run: LIVE_SMOKE=1 TEST_PAID_JWT=<token> PUBLIC_SUPABASE_URL=<url> \
#        npm run test:unit -- --run src/lib/chat/techniques/__tests__/smoke/prompt-synthesizer.smoke.test.ts
