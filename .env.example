# Cryptex OSS environment variables. Everything is OPTIONAL — the static
# bundle works with zero env set. Copy to `.env` for docker-compose, or set
# in your hosting platform's UI (Dokploy, Coolify, Render, Fly, etc.).

# ---------------------------------------------------------------------------
# Build-time variables (Vite inlines these into the static bundle — rebuild
# the image to change them)
# ---------------------------------------------------------------------------

# Path prefix the app is served under. Empty for root (e.g. cryptex.example.com).
# Set to "/cryptex" if serving at example.com/cryptex (GitHub Pages subpath, etc.).
BASE_PATH=

# ---------------------------------------------------------------------------
# Runtime variables (applied per-container, no rebuild needed)
# ---------------------------------------------------------------------------

# Host port to bind the container's port 80 to. Standalone docker-compose only;
# behind a reverse proxy (Traefik, Caddy, nginx) leave default and route via
# the proxy.
CRYPTEX_PORT=8080

# Container timezone for server logs. Any valid IANA tz database name
# (e.g. "Asia/Kolkata", "America/New_York", "Europe/Berlin").
TZ=UTC

# ---------------------------------------------------------------------------
# Note on provider keys + Cloud Sync
# ---------------------------------------------------------------------------
# Cryptex OSS is browser-only and BYOK (bring your own key). Provider API
# keys (OpenRouter, Anthropic, OpenAI-compatible endpoints) NEVER touch this
# file or any server. They live in your browser's localStorage and are sent
# directly to the provider you configured.
#
# Optional Cloud Sync (history + Vault customs) uses BYO Supabase — enter
# your Supabase URL + anon key once in Settings → Cloud Sync. That data
# never touches this env file either.
