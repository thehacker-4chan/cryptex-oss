# Cryptex environment variables — copy to `.env` for docker-compose or configure
# in Dokploy's "Build Variables" pane.
#
# Everything is optional; Cryptex works with zero env set.

# ---------------------------------------------------------------------------
# Build-time variables (baked into the static bundle — rebuild to change)
# ---------------------------------------------------------------------------

# Path prefix the app is served under. Empty for root (e.g. cryptex.example.com).
# Set to "/cryptex" if serving at example.com/cryptex (GitHub Pages subpath, etc.).
BASE_PATH=

# Google AdSense publisher ID (starts with "ca-pub-"). Unset = no ads,
# no consent banner, no Google script loaded. Only activates on /guide and
# /about routes; tool pages are always ad-free regardless.
PUBLIC_ADSENSE_CLIENT=

# ---------------------------------------------------------------------------
# Runtime variables (applied per-container, no rebuild needed)
# ---------------------------------------------------------------------------

# Host port to bind the container's port 80 to. Only relevant for standalone
# docker-compose; Dokploy's Traefik handles routing so leave default.
CRYPTEX_PORT=8080

# Timezone for server logs. Valid TZ database name (e.g. "Asia/Kolkata").
TZ=UTC

# Auth v2 (sub-project E). Set these to your Supabase project values.
# Leave VITE_AUTH_ENABLED unset or "false" to keep the app in local-only mode.
VITE_AUTH_ENABLED=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
